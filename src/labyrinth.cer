fn Labyrinth::render(labyrinth: &u16) {
    let y = HEIGHT in for y downto 0 {
        let x = WIDTH in for x downto 0 {
            render_tile(
                (WIDTH - x) << 2,
                (HEIGHT - y) << 2,
                TILES[^labyrinth],
            );
        }
    }
}

