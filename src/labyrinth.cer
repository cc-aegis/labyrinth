const BLACK: u16 = 0;
const WHITE: u16 = 255;

const TILES: &&u16 = &[
    &[BLACK, BLACK, BLACK, BLACK,    BLACK, BLACK, BLACK, BLACK,    BLACK, BLACK, BLACK, BLACK,    BLACK, BLACK, BLACK, BLACK], // SOLID
    &[BLACK, WHITE, WHITE, BLACK,    BLACK, WHITE, WHITE, BLACK,    BLACK, WHITE, WHITE, BLACK,    BLACK, BLACK, BLACK, BLACK], // N
    &[BLACK, BLACK, BLACK, BLACK,    WHITE, WHITE, WHITE, BLACK,    WHITE, WHITE, WHITE, BLACK,    BLACK, BLACK, BLACK, BLACK], //  W
    &[BLACK, WHITE, WHITE, BLACK,    WHITE, WHITE, WHITE, BLACK,    WHITE, WHITE, WHITE, BLACK,    BLACK, BLACK, BLACK, BLACK], // NW
    &[BLACK, BLACK, BLACK, BLACK,    BLACK, WHITE, WHITE, WHITE,    BLACK, WHITE, WHITE, WHITE,    BLACK, BLACK, BLACK, BLACK], //   E
    &[BLACK, WHITE, WHITE, BLACK,    BLACK, WHITE, WHITE, WHITE,    BLACK, WHITE, WHITE, WHITE,    BLACK, BLACK, BLACK, BLACK], // N E
    &[BLACK, BLACK, BLACK, BLACK,    WHITE, WHITE, WHITE, WHITE,    WHITE, WHITE, WHITE, WHITE,    BLACK, BLACK, BLACK, BLACK], //  WE
    &[BLACK, WHITE, WHITE, BLACK,    WHITE, WHITE, WHITE, WHITE,    WHITE, WHITE, WHITE, WHITE,    BLACK, BLACK, BLACK, BLACK], // NWE
    &[BLACK, BLACK, BLACK, BLACK,    BLACK, WHITE, WHITE, BLACK,    BLACK, WHITE, WHITE, BLACK,    BLACK, WHITE, WHITE, BLACK], //    S
    &[BLACK, WHITE, WHITE, BLACK,    BLACK, WHITE, WHITE, BLACK,    BLACK, WHITE, WHITE, BLACK,    BLACK, WHITE, WHITE, BLACK], // N  S
    &[BLACK, BLACK, BLACK, BLACK,    WHITE, WHITE, WHITE, BLACK,    WHITE, WHITE, WHITE, BLACK,    BLACK, WHITE, WHITE, BLACK], //  W S
    &[BLACK, WHITE, WHITE, BLACK,    WHITE, WHITE, WHITE, BLACK,    WHITE, WHITE, WHITE, BLACK,    BLACK, WHITE, WHITE, BLACK], // NW S
    &[BLACK, BLACK, BLACK, BLACK,    BLACK, WHITE, WHITE, WHITE,    BLACK, WHITE, WHITE, WHITE,    BLACK, WHITE, WHITE, BLACK], //   ES
    &[BLACK, WHITE, WHITE, BLACK,    BLACK, WHITE, WHITE, WHITE,    BLACK, WHITE, WHITE, WHITE,    BLACK, WHITE, WHITE, BLACK], // N ES
    &[BLACK, BLACK, BLACK, BLACK,    WHITE, WHITE, WHITE, WHITE,    WHITE, WHITE, WHITE, WHITE,    BLACK, WHITE, WHITE, BLACK], //  WES
    &[BLACK, WHITE, WHITE, BLACK,    WHITE, WHITE, WHITE, WHITE,    WHITE, WHITE, WHITE, WHITE,    BLACK, WHITE, WHITE, BLACK], // NWES
];